#!/usr/bin/env ruby
# frozen_string_literal: true

require 'pathname'
lib_path = Pathname.new(__FILE__).realpath.dirname.parent.join('lib')
$LOAD_PATH.unshift(lib_path) unless $LOAD_PATH.include?(lib_path)

require 'cornix/file_renamer'
require 'optparse'
require 'json'

# コマンドラインオプション
options = {
  old_path: nil,
  new_basename: nil,
  name: nil,
  description: nil,
  batch_file: nil,
  dry_run: false,
  cleanup_backup: false,
  config_dir: 'config'
}

OptionParser.new do |opts|
  opts.banner = "Usage: #{File.basename(__FILE__)} [options]"

  opts.on('--old-path PATH', 'Path to the file to rename') do |path|
    options[:old_path] = path
  end

  opts.on('--new-basename NAME', 'New basename for the file (with index prefix)') do |name|
    options[:new_basename] = name
  end

  opts.on('--name NAME', 'Update the "name" field in YAML') do |name|
    options[:name] = name
  end

  opts.on('--description DESC', 'Update the "description" field in YAML') do |desc|
    options[:description] = desc
  end

  opts.on('--batch FILE', 'JSON file with batch rename plans') do |file|
    options[:batch_file] = file
  end

  opts.on('--dry-run', 'Preview without applying changes') do
    options[:dry_run] = true
  end

  opts.on('--cleanup-backup', 'Delete backup on success') do
    options[:cleanup_backup] = true
  end

  opts.on('--config-dir DIR', 'Configuration directory (default: config)') do |dir|
    options[:config_dir] = dir
  end

  opts.on('-h', '--help', 'Show this help message') do
    puts opts
    exit 0
  end
end.parse!

# dry-runモードではバックアップを作成しない
backup_on_init = !options[:dry_run]

begin
  renamer = Cornix::FileRenamer.new(options[:config_dir], backup_on_init: backup_on_init)

  result = if options[:batch_file]
    # バッチモード
    unless File.exist?(options[:batch_file])
      { success: false, error: "Batch file not found: #{options[:batch_file]}" }
    else
      plans_json = File.read(options[:batch_file])
      plans = JSON.parse(plans_json, symbolize_names: true)

      if options[:dry_run]
        # dry-runモード: 検証のみ
        validation_results = plans.map.with_index do |plan, idx|
          errors = renamer.send(:validate_rename_plan, plan)
          { plan_index: idx, plan: plan, errors: errors }
        end

        {
          success: validation_results.all? { |r| r[:errors].empty? },
          dry_run: true,
          validation_results: validation_results
        }
      else
        # 実行モード
        result = renamer.rename_batch(plans)

        # 成功時にバックアップをクリーンアップ（オプション）
        if result[:success] && options[:cleanup_backup]
          cleanup_success = renamer.cleanup_backup(result[:backup_path])
          result[:backup_cleaned_up] = cleanup_success
        end

        result
      end
    end
  else
    # 単一ファイルモード
    unless options[:old_path] && options[:new_basename]
      { success: false, error: 'Both --old-path and --new-basename are required for single file mode' }
    else
      content_updates = {}
      content_updates['name'] = options[:name] if options[:name]
      content_updates['description'] = options[:description] if options[:description]

      if options[:dry_run]
        # dry-runモード: 検証のみ
        plan = {
          old_path: options[:old_path],
          new_basename: options[:new_basename],
          content_updates: content_updates
        }
        errors = renamer.send(:validate_rename_plan, plan)
        {
          success: errors.empty?,
          dry_run: true,
          plan: plan,
          validation_errors: errors
        }
      else
        # 実行モード
        result = renamer.rename_file(
          options[:old_path],
          options[:new_basename],
          content_updates: content_updates
        )

        # 成功時にバックアップをクリーンアップ（オプション）
        if result[:success] && options[:cleanup_backup] && renamer.backup_path
          cleanup_success = renamer.cleanup_backup
          result[:backup_cleaned_up] = cleanup_success
        end

        result
      end
    end
  end

  # 結果を出力
  puts JSON.pretty_generate(result)

  # 終了コード
  exit(result[:success] ? 0 : 1)

rescue StandardError => e
  # エラーハンドリング
  error_result = {
    success: false,
    error: e.message,
    backtrace: e.backtrace[0..5]
  }
  puts JSON.pretty_generate(error_result)
  exit 1
end
