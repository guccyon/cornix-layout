#!/usr/bin/env ruby
# frozen_string_literal: true

require 'fileutils'
require 'yaml'
require 'digest'
require_relative '../lib/cornix/decompiler'

def show_usage
  puts <<~USAGE
    Usage: decompile [LAYOUT_FILE]

    Arguments:
      LAYOUT_FILE  Path to layout.vil file (default: tmp/layout.vil)

    Examples:
      decompile                    # Use default tmp/layout.vil
      decompile ~/Downloads/layout.vil
      decompile /path/to/custom.vil

    The decompiled YAML files will be generated in the config/ directory.

    Safety:
      - If config/ directory already exists, a .lock file check will be performed
      - Use --force to override existing config (not recommended)
  USAGE
end

def check_config_lock(config_dir)
  lock_file = "#{config_dir}/.decompile.lock"

  if File.exist?(config_dir) && Dir.exist?(config_dir)
    # config ディレクトリが存在する場合、重要なファイルがあるかチェック
    has_layers = Dir.exist?("#{config_dir}/layers") && !Dir.empty?("#{config_dir}/layers")
    has_macros = Dir.exist?("#{config_dir}/macros") && !Dir.empty?("#{config_dir}/macros")

    if has_layers || has_macros
      puts "⚠️  Error: config/ directory already contains configuration files."
      puts ""
      puts "To protect your existing configuration, decompile has been blocked."
      puts ""
      puts "Options:"
      puts "  1. Backup your config/ directory and remove it"
      puts "  2. Use 'ruby bin/compile' to compile existing config"
      puts "  3. Create a new directory for decompilation"
      puts ""
      puts "Example:"
      puts "  mv config config.backup"
      puts "  ruby bin/decompile ~/Downloads/layout.vil"
      exit 1
    end
  end
end

# パラメータ解析
if ARGV[0] == '-h' || ARGV[0] == '--help'
  show_usage
  exit 0
end

vil_file = ARGV[0] || File.expand_path('../tmp/layout.vil', __dir__)
output_dir = File.expand_path('../config', __dir__)

# ファイル存在チェック
unless File.exist?(vil_file)
  puts "Error: #{vil_file} not found"
  puts ""
  show_usage
  exit 1
end

# 既存config保護チェック
check_config_lock(output_dir)

# デコンパイル実行
puts "Decompiling: #{vil_file}"
puts "Output to: #{output_dir}"
puts ""

decompiler = Cornix::Decompiler.new(vil_file)
decompiler.decompile(output_dir)

# ロックファイル作成
lock_file = "#{output_dir}/.decompile.lock"
File.write(lock_file, {
  'decompiled_at' => Time.now.to_s,
  'source_file' => vil_file,
  'checksum' => Digest::SHA256.file(vil_file).hexdigest
}.to_yaml)

puts "\n✓ All files generated in: #{output_dir}"
puts "✓ Lock file created: #{lock_file}"

